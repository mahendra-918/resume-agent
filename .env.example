# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=groq          # groq | gemini | ollama
GROQ_API_KEY=              # get from console.groq.com (free)
GEMINI_API_KEY=            # get from aistudio.google.com (free)
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.0

# ── Platform credentials ──────────────────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
INTERNSHALA_EMAIL=
INTERNSHALA_PASSWORD=
NAUKRI_EMAIL=
NAUKRI_PASSWORD=
WELLFOUND_EMAIL=
WELLFOUND_PASSWORD=

# ── Job search ────────────────────────────────────────────────────────────────
JOB_LOCATION=Remote
JOB_TYPE=internship
MAX_APPLICATIONS=5
MIN_RELEVANCE_SCORE=0.5
RESULTS_PER_PLATFORM=10

# ── Platform toggles ──────────────────────────────────────────────────────────
USE_LINKEDIN=true
USE_INTERNSHALA=false
USE_NAUKRI=false
USE_WELLFOUND=false

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output/resumes
DB_PATH=./output/applications_log.db
CHECKPOINT_DB_PATH=./output/checkpoints.db

# ── Browser ───────────────────────────────────────────────────────────────────
HEADLESS=true
BROWSER_SLOW_MO=500

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
