# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

# ── Platform credentials ──────────────────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
INTERNSHALA_EMAIL=
INTERNSHALA_PASSWORD=
NAUKRI_EMAIL=
NAUKRI_PASSWORD=
WELLFOUND_EMAIL=
WELLFOUND_PASSWORD=

# ── Job search ────────────────────────────────────────────────────────────────
JOB_LOCATION=Bangalore, India
JOB_TYPE=internship
MAX_APPLICATIONS=20
MIN_RELEVANCE_SCORE=0.6
RESULTS_PER_PLATFORM=20

# ── Platform toggles ──────────────────────────────────────────────────────────
USE_LINKEDIN=true
USE_INTERNSHALA=true
USE_NAUKRI=true
USE_WELLFOUND=true

# ── Output ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output/resumes
DB_PATH=./output/applications_log.db
CHECKPOINT_DB_PATH=./output/checkpoints.db

# ── Browser ───────────────────────────────────────────────────────────────────
HEADLESS=true
BROWSER_SLOW_MO=500

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
