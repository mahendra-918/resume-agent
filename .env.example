# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Platform credentials ──────────────────────────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
NAUKRI_EMAIL=
NAUKRI_PASSWORD=
INTERNSHALA_EMAIL=
INTERNSHALA_PASSWORD=
WELLFOUND_EMAIL=
WELLFOUND_PASSWORD=

# ── Agent behaviour ───────────────────────────────────────────────────────────
MAX_APPLICATIONS_PER_RUN=10
DRY_RUN=false

# ── Paths ─────────────────────────────────────────────────────────────────────
OUTPUT_DIR=output
DB_PATH=output/applications_log.db

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
