---
title: Resume Agent — LLM Chain Flow (Groq + LangChain)
---
flowchart TD
    subgraph CHAIN1["Chain 1 — Resume Parser"]
        C1A["Input: raw resume text\n.md / .pdf / .docx content"] --> C1B
        C1B["ChatPromptTemplate\nRESUME_PARSE_PROMPT\nwith {resume_text} variable"] --> C1C
        C1C["ChatGroq\nllama-3.3-70b-versatile\nawait chain.ainvoke"] --> C1D
        C1D["LLM Response\nJSON string"] --> C1E
        C1E["_parse_json\nStrip markdown fences\njson.loads"] --> C1F
        C1F["ParsedResume object\nname, email, skills\nexperience, projects etc."]
    end

    subgraph CHAIN2["Chain 2 — Query Generator"]
        C2A["Input: target_roles\ntop_skills, experience_summary"] --> C2B
        C2B["ChatPromptTemplate\nQUERY_GENERATOR_PROMPT"] --> C2C
        C2C["ChatGroq → ainvoke"] --> C2D
        C2D["Parse JSON → list of strings"] --> C2E
        C2E["3–5 search query strings\ne.g. 'Python ML intern Bangalore'"]
    end

    subgraph CHAIN3["Chain 3 — Job Ranker"]
        C3A["Input: candidate_skills\ncandidate_experience\njob_title, job_description\nmax 2000 chars"] --> C3B
        C3B["ChatPromptTemplate\nJOB_RANK_PROMPT"] --> C3C
        C3C["ChatGroq → ainvoke"] --> C3D
        C3D["Parse JSON dict"] --> C3E
        C3E["relevance_score: float 0–1\nmatched_skills: list\nmissing_skills: list\nCalled once per job found"]
    end

    subgraph CHAIN4["Chain 4 — Resume Tailor"]
        C4A["Input: job_title, company\njob_description max 3000 chars\nresume_json full resume"] --> C4B
        C4B["ChatPromptTemplate\nRESUME_TAILOR_PROMPT"] --> C4C
        C4C["ChatGroq → ainvoke"] --> C4D
        C4D["Parse JSON dict"] --> C4E
        C4E["TailoredResume fields\ntailored_summary\nhighlighted_skills\nreordered_projects\nadded_keywords"]
    end

    START([Pipeline\nStarts]) --> CHAIN1
    CHAIN1 --> CHAIN2
    CHAIN2 --> SC["Search Jobs\npython-jobspy\nno LLM here"]
    SC --> CHAIN3
    CHAIN3 --> CHAIN4
    CHAIN4 --> AP["Playwright\nApply to job\nno LLM here"]

    style START fill:#1F4E79,color:#fff
    style SC fill:#374151,color:#fff
    style AP fill:#374151,color:#fff
    style CHAIN1 fill:#1a1a2e,color:#CDD6F4
    style CHAIN2 fill:#1a1a2e,color:#CDD6F4
    style CHAIN3 fill:#1a1a2e,color:#CDD6F4
    style CHAIN4 fill:#1a1a2e,color:#CDD6F4
    style C1C fill:#065F46,color:#fff
    style C2C fill:#065F46,color:#fff
    style C3C fill:#065F46,color:#fff
    style C4C fill:#065F46,color:#fff
